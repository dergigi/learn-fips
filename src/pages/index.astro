---
import Base from "../layouts/Base.astro";
import { lessons } from "../data/lessons";
import HeroMesh from "../components/HeroMesh";
---

<Base title="Learn FIPS">
  <section class="hex-bg relative overflow-hidden">
    <div class="hero-mesh-wrap absolute inset-0">
      <HeroMesh client:load />
      <div class="hero-mesh-fade absolute inset-0 pointer-events-none"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 pt-20 pb-40 md:pb-48 text-center">
      <p class="text-fips-accent font-mono text-sm tracking-widest uppercase mb-4">
        Interactive Protocol Guide
      </p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">
        Learn <span class="text-fips-accent">FIPS</span>
      </h1>
      <p class="text-fips-muted text-lg max-w-xl mx-auto mb-8">
        FIPS is a self-organizing encrypted mesh that works over anything you can send packets
        through. This site teaches you how it works, layer by layer, with <a
          href="/interactive"
          class="subtle-link">interactive simulations</a
        >.
      </p>
      <a
        href={`/lessons/${lessons[0]!.slug}`}
        class="inline-block bg-fips-accent text-fips-bg font-semibold px-6 py-3 rounded-lg hover:bg-fips-accent/90 transition-colors"
      >
        Start Learning
      </a>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
      <h2 class="text-lg font-semibold">Lessons</h2>
      <div class="flex items-center gap-3">
        <span id="progress-text" class="text-fips-muted text-sm font-mono"></span>
        <button
          id="reset-progress-btn"
          type="button"
          class="hidden text-xs font-mono text-fips-muted hover:text-fips-red transition-colors border border-fips-border hover:border-fips-red/40 rounded px-2 py-1"
        >
          Reset progress
        </button>
      </div>
    </div>
    <div class="grid gap-4">
      {
        lessons.map((lesson) => (
          <a
            href={`/lessons/${lesson.slug}`}
            data-slug={lesson.slug}
            data-lesson={lesson.number}
            class="lesson-card group flex items-start gap-4 p-4 rounded-lg border border-fips-border bg-fips-surface/50 hover:border-fips-accent/40 transition-colors"
          >
            <span class="lesson-badge flex-shrink-0 w-8 h-8 rounded-full bg-fips-accent/10 text-fips-accent flex items-center justify-center font-mono text-sm font-bold">
              {lesson.number}
            </span>
            <div class="flex-1">
              <div class="flex items-baseline justify-between gap-2 flex-wrap">
                <h3 class="font-semibold group-hover:text-fips-accent transition-colors">
                  {lesson.title}
                </h3>
                <span class="lesson-status text-xs font-mono text-fips-muted" />
              </div>
              <p class="text-fips-muted text-sm mt-1">{lesson.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <script>
    import {
      loadProgress,
      resetProgress,
      isVisited,
      isPassed,
      isCompleted,
      LESSONS_WITH_QUIZ,
    } from "../lib/progress";

    const lessonSlugByNumber = new Map<number, string>();

    function render() {
      const p = loadProgress(lessonSlugByNumber);
      const cards = document.querySelectorAll<HTMLElement>(".lesson-card");
      const total = cards.length;
      let completed = 0;
      let anyProgress = false;

      cards.forEach((card) => {
        const slug = card.dataset.slug ?? "";
        const badge = card.querySelector(".lesson-badge");
        const status = card.querySelector<HTMLElement>(".lesson-status");
        const visited = isVisited(p, slug);
        const passed = isPassed(p, slug);
        const done = isCompleted(p, slug);
        if (visited) anyProgress = true;
        if (done) completed++;

        if (badge) {
          badge.classList.remove(
            "bg-fips-accent/10",
            "text-fips-accent",
            "bg-fips-green/20",
            "text-fips-green",
            "bg-fips-muted/10",
            "text-fips-muted"
          );
          if (done) {
            badge.classList.add("bg-fips-green/20", "text-fips-green");
            badge.textContent = "✓";
          } else if (visited) {
            badge.classList.add("bg-fips-muted/10", "text-fips-muted");
            badge.textContent = card.dataset.lesson || "";
          } else {
            badge.classList.add("bg-fips-accent/10", "text-fips-accent");
            badge.textContent = card.dataset.lesson || "";
          }
        }

        if (status) {
          if (done) {
            status.textContent = "Completed";
            status.className = "lesson-status text-xs font-mono text-fips-green";
          } else if (passed) {
            status.textContent = "Quiz passed";
            status.className = "lesson-status text-xs font-mono text-fips-green";
          } else if (visited) {
            status.textContent = LESSONS_WITH_QUIZ.has(slug) ? "In progress" : "Visited";
            status.className = "lesson-status text-xs font-mono text-fips-muted";
          } else {
            status.textContent = "";
            status.className = "lesson-status text-xs font-mono text-fips-muted";
          }
        }
      });

      const progressText = document.getElementById("progress-text");
      if (progressText) progressText.textContent = `${completed}/${total} completed`;

      const resetBtn = document.getElementById("reset-progress-btn");
      if (resetBtn) resetBtn.classList.toggle("hidden", !anyProgress);
    }

    function wire() {
      // lessonSlugByNumber is derived from the currently visible DOM, so
      // re-derive it when the page is swapped in by the view router.
      lessonSlugByNumber.clear();
      document.querySelectorAll<HTMLElement>(".lesson-card").forEach((card) => {
        const n = Number(card.dataset.lesson);
        const slug = card.dataset.slug;
        if (n && slug) lessonSlugByNumber.set(n, slug);
      });
      render();
      const btn = document.getElementById("reset-progress-btn");
      if (btn && btn.dataset.wired !== "1") {
        btn.dataset.wired = "1";
        btn.addEventListener("click", () => {
          if (!confirm("Reset all lesson progress and quiz attempts?")) return;
          resetProgress();
          render();
        });
      }
    }

    document.addEventListener("astro:page-load", wire);
  </script>
</Base>

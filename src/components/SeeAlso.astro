---
import { glossary } from "../data/glossary";

interface Props {
  /** Glossary term ids to surface at the bottom of a lesson. */
  terms: string[];
}

const { terms } = Astro.props;
const items = terms
  .map((id) => glossary.find((t) => t.id === id))
  .filter((t): t is (typeof glossary)[number] => Boolean(t));
---

{
  items.length > 0 && (
    <aside class="mt-8 mb-4 rounded-lg border border-fips-border bg-fips-surface/30 p-4 not-prose">
      <p class="text-xs text-fips-muted mb-3 font-mono uppercase tracking-wide">See also</p>
      <ul class="space-y-2 text-sm">
        {items.map((t) => (
          <li>
            <a
              href={`/glossary#${t.id}`}
              class="text-fips-accent hover:underline font-mono text-xs"
            >
              {t.term}
            </a>
            <span class="text-fips-muted"> — {t.summary}</span>
          </li>
        ))}
      </ul>
    </aside>
  )
}

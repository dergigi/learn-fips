---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { lessons } from "../data/lessons";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "An interactive guide to the FIPS mesh protocol",
  ogImage,
} = Astro.props;
const currentPath = Astro.url.pathname;
const site = Astro.site ?? new URL("https://learn-fips.vercel.app");
const canonical = new URL(currentPath, site).toString();
const lessonSlug = currentPath.match(/\/lessons\/([^/]+)/)?.[1];
const isGlossary = currentPath.startsWith("/glossary");
const ogSlug = lessonSlug ?? (isGlossary ? "glossary" : "default");
const resolvedOgImage = ogImage ?? `/og/${ogSlug}.png`;
const ogImageUrl = new URL(resolvedOgImage, site).toString();
const fullTitle = `${title} | Learn FIPS`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Learn FIPS" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-dvh">
    <nav
      transition:persist
      transition:name="site-nav"
      class="border-b border-fips-border bg-fips-surface/80 backdrop-blur-sm sticky top-0 z-50"
    >
      <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-fips-accent font-bold tracking-tight">
          <span class="text-xl">⬡</span>
          <span>Learn FIPS</span>
        </a>
        <div class="hidden md:flex items-center gap-1 text-sm">
          {
            lessons.map((l) => {
              const href = `/lessons/${l.slug}`;
              const active = currentPath.startsWith(href);
              return (
                <a
                  href={href}
                  class:list={[
                    "px-2 py-1 rounded transition-colors",
                    active
                      ? "text-fips-accent bg-fips-accent/10"
                      : "text-fips-muted hover:text-fips-text",
                  ]}
                >
                  {l.number}
                </a>
              );
            })
          }
        </div>
        <div class="flex items-center gap-3">
          <a
            href="/glossary"
            class:list={[
              "text-sm transition-colors hidden sm:inline",
              currentPath.startsWith("/glossary")
                ? "text-fips-accent"
                : "text-fips-muted hover:text-fips-text",
            ]}
          >
            Glossary
          </a>
          <button
            id="mobile-menu-btn"
            class="md:hidden text-fips-muted hover:text-fips-text p-1"
            aria-label="Toggle lesson menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <line x1="3" y1="5" x2="17" y2="5"></line>
              <line x1="3" y1="10" x2="17" y2="10"></line>
              <line x1="3" y1="15" x2="17" y2="15"></line>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile dropdown -->
      <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-fips-border bg-fips-surface px-4 py-3"
      >
        <div class="grid grid-cols-2 gap-2">
          {
            lessons.map((l) => {
              const href = `/lessons/${l.slug}`;
              const active = currentPath.startsWith(href);
              return (
                <a
                  href={href}
                  class:list={[
                    "px-3 py-2 rounded text-sm transition-colors",
                    active
                      ? "text-fips-accent bg-fips-accent/10"
                      : "text-fips-muted hover:text-fips-text hover:bg-fips-surface",
                  ]}
                >
                  <span class="font-mono text-xs mr-1">{l.number}.</span> {l.title}
                </a>
              );
            })
          }
          <a
            href="/glossary"
            class:list={[
              "col-span-2 px-3 py-2 rounded text-sm transition-colors border-t border-fips-border mt-1 pt-2",
              currentPath.startsWith("/glossary")
                ? "text-fips-accent bg-fips-accent/10"
                : "text-fips-muted hover:text-fips-text",
            ]}
          >
            <span class="font-mono text-xs mr-1">§</span> Glossary
          </a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-fips-border py-8 text-center text-fips-muted text-sm">
      <p>
        Built to teach <a
          href="https://fips.network"
          target="_blank"
          rel="noopener"
          class="text-fips-accent underline">FIPS</a
        >. Protocol specs at <a
          href="https://github.com/jmcorgan/fips/tree/master/docs/design"
          target="_blank"
          rel="noopener"
          class="text-fips-accent underline">docs/design</a
        >. <a
          href="https://github.com/dergigi/learn-fips"
          target="_blank"
          rel="noopener"
          class="text-fips-accent underline"
          aria-label="View the source of this site on GitHub">Source</a
        > on GitHub.
      </p>
    </footer>

    <script>
      import { markVisited } from "../lib/progress";

      function wireMobileMenu() {
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");
        if (!btn || btn.dataset.wired === "1") return;
        btn.dataset.wired = "1";
        btn.addEventListener("click", () => {
          const open = menu?.classList.toggle("hidden") === false;
          btn.setAttribute("aria-expanded", String(open));
        });
      }

      function onPageLoad() {
        wireMobileMenu();
        // Mark the current lesson as visited in the shared progress store.
        const slug = window.location.pathname.match(/\/lessons\/([^/]+)/)?.[1];
        if (slug) markVisited(slug);
      }

      document.addEventListener("astro:page-load", onPageLoad);
    </script>
  </body>
</html>
